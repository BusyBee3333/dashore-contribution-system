# Discord Bot Configuration
# Copy this to .env and fill in your values

# Your bot token from Discord Developer Portal
BOT_TOKEN=your_bot_token_here

# Your application's client ID
CLIENT_ID=your_client_id_here

# Guild ID for guild-specific command registration (instant, good for development)
GUILD_ID=1449158500344270961

# Absolute path to the contributions SQLite database
DB_PATH=/path/to/contribution-system/data/contributions.db
